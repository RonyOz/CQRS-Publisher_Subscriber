# ══════════════════════════════════════════════════════════════
#  Variables de entorno para el proyecto CQRS + Pub/Sub
#  Instrucciones:
#    cp .env.example .env
#    Editar .env con tus valores reales
#  NUNCA commitear el archivo .env al repositorio
# ══════════════════════════════════════════════════════════════

# ── Azure Service Bus (requerido para el módulo Pub/Sub) ──────
# Obtener desde: Azure Portal → Service Bus Namespace → Shared Access Policies → RootManageSharedAccessKey
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://TU-NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=TU-CLAVE-AQUI

# ── CQRS Ports (opcionales, valores por defecto incluidos) ────
# COMMAND_SERVICE_PORT=3001
# QUERY_SERVICE_PORT=3002
